set incsearch
set visualbell
set noerrorbells
set belloff=all
set clipboard+=unnamedplus
set nu
set rnu

nnoremap ö $
vnoremap ö $
nnoremap Y y$

inoremap jk <Esc>
inoremap kj <Esc>

" Make sure C-j and C-k are using vim (in ideavim settings)
inoremap <C-j> <down>
inoremap <C-k> <up>
nnoremap <C-j> <down>
nnoremap <C-k> <up>

inoremap <C-v> :action EditorPaste<CR>

nnoremap <C-b> :action ToggleLineBreakpoint<CR>

nnoremap fg :action FindInPath<CR>
nnoremap ff :action GotoFile<CR>

nnoremap <S-k> :action ShowHoverInfo<CR>

nnoremap <C-n> :action GotoNextError<CR>
nnoremap <C-p> :action GotoPreviousError<CR>

nnoremap gi :action GotoImplementation<CR>
nnoremap gR :action GotoDeclaration<CR>
nnoremap gr :action GotoDeclaration<CR>
nnoremap gd :action GotoDeclaration<CR>
nnoremap gs :action GotoSuperMethod<CR>

" Inc/Inc-rement selection
vnoremap <C-k> :action EditorSelectWord<CR>
vnoremap <C-j> :action EditorUnSelectWord<CR>

" Highlight copied text
Plug 'machakann/vim-highlightedyank'
" Commentary plugin
Plug 'tpope/vim-commentary'
